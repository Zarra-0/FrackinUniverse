{
  "animatedParts" : {
    "stateTypes" : {
      "boothState" : {
        "default" : "idle",
        "states" : {
          "idle" : {
            "frames" : 1,
            "cycle" : 3.0,
            "mode" : "transition",
            "transition" : "blink"
          },
          "blink" : {
            "frames" : 1,
            "cycle" : 0.1,
            "mode" : "transition",
            "transition" : "idle"
          },
          "cry" : {
            "frames" : 6,
            "cycle" : 1.0,
            "mode" : "loop"
          }
        }
      }
    },

    "parts" : {
      "fuprotectoratesadavian" : {
        "properties" : {
          "centered" : false
        },

        "partStates" : {
          "fuprotectoratesadavianState" : {
            "idle" : {
              "properties" : {
                "image" : "<partImage>:idle"
              }
            },
            "blink" : {
              "properties" : {
                "image" : "<partImage>:blink"
              }
            },
            "cry" : {
              "properties" : {
                "image" : "<partImage>:cry.<frame>"
              }
            }
          }
        }
      }
    }
  },

  "sounds" : {
    "chatter" : [
      "/sfx/humanoid/avian_chatter_female1.ogg",
      "/sfx/humanoid/avian_chatter_female2.ogg",
      "/sfx/humanoid/avian_chatter_female3.ogg"
    ]
  }
}
